{
  "title": "cueq — API Overview",
  "uid": "cueq-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"cueq_api\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP 5xx Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(http_requests_total{job=\"cueq_api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"cueq_api\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cueq_api\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cueq_api\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"cueq_api\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Audit Entries Written (last hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(cueq_audit_entries_total[1h])",
          "legendFormat": "entries"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Terminal Heartbeats",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "count(cueq_terminal_last_heartbeat_seconds > (time() - 300))",
          "legendFormat": "online"
        }
      ]
    }
  ]
}

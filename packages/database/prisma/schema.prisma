// cueq — Prisma Schema
// ======================
// This is the initial schema stub. Models correspond to the domain entities
// defined in ARCHITECTURE.md and _ideas/PRD.md §9.
//
// Run `pnpm db:generate` to generate the Prisma Client.
// Run `pnpm db:migrate` to apply migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & Organization
// ---------------------------------------------------------------------------

model Person {
  id                String   @id @default(cuid())
  externalId        String?  @unique /// HR/IdM external identifier
  firstName         String
  lastName          String
  email             String   @unique
  role              Role     @default(EMPLOYEE)
  organizationUnitId String
  organizationUnit  OrganizationUnit @relation(fields: [organizationUnitId], references: [id])
  supervisorId      String?
  supervisor        Person?  @relation("SupervisorRelation", fields: [supervisorId], references: [id])
  subordinates      Person[] @relation("SupervisorRelation")
  workTimeModelId   String?
  workTimeModel     WorkTimeModel? @relation(fields: [workTimeModelId], references: [id])
  bookings          Booking[]
  absences          Absence[]
  timeAccounts      TimeAccount[]
  onCallDeployments OnCallDeployment[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("persons")
}

enum Role {
  EMPLOYEE      /// Mitarbeitende
  TEAM_LEAD     /// Teamleitung / Vorgesetzte
  SHIFT_PLANNER /// Dienstplaner*in
  HR            /// Personalstelle
  PAYROLL       /// Bezügestelle
  ADMIN         /// IT/Administration
  DATA_PROTECTION /// Datenschutz
  WORKS_COUNCIL /// Personalrat
}

model OrganizationUnit {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    OrganizationUnit?  @relation("OUHierarchy", fields: [parentId], references: [id])
  children  OrganizationUnit[] @relation("OUHierarchy")
  persons   Person[]
  rosters   Roster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_units")
}

// ---------------------------------------------------------------------------
// Work Time Models & Configuration
// ---------------------------------------------------------------------------

model WorkTimeModel {
  id              String   @id @default(cuid())
  name            String   /// e.g. "Gleitzeit Vollzeit", "Schicht Pforte 3x8"
  type            WorkTimeModelType
  weeklyHours     Decimal  /// e.g. 39.83 for TV-L full-time
  dailyTargetHours Decimal? /// e.g. 7.97 for 5-day week
  coreTimeStart   String?  /// e.g. "09:00" (Gleitzeit only)
  coreTimeEnd     String?  /// e.g. "15:00" (Gleitzeit only)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  persons         Person[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("work_time_models")
}

enum WorkTimeModelType {
  FLEXTIME   /// Gleitzeit
  FIXED      /// Fixzeit
  SHIFT      /// Schichtmodell
}

// ---------------------------------------------------------------------------
// Time Tracking
// ---------------------------------------------------------------------------

model Booking {
  id          String      @id @default(cuid())
  personId    String
  person      Person      @relation(fields: [personId], references: [id])
  timeTypeId  String
  timeType    TimeType    @relation(fields: [timeTypeId], references: [id])
  startTime   DateTime
  endTime     DateTime?
  source      BookingSource
  note        String?     /// Required for corrections/manual entries
  shiftId     String?
  shift       Shift?      @relation(fields: [shiftId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([personId, startTime])
  @@map("bookings")
}

enum BookingSource {
  TERMINAL   /// Honeywell terminal
  WEB        /// Web self-service
  MOBILE     /// Mobile app (future)
  IMPORT     /// Batch import
  MANUAL     /// Emergency/manual entry
  CORRECTION /// Post-close HR correction
}

model TimeType {
  id          String    @id @default(cuid())
  code        String    @unique /// e.g. "WORK", "PAUSE", "ON_CALL", "DEPLOYMENT"
  name        String    /// Display name (German)
  nameEn      String?   /// Display name (English)
  category    TimeTypeCategory
  isActive    Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("time_types")
}

enum TimeTypeCategory {
  WORK          /// Regular working time
  PAUSE         /// Break
  ON_CALL       /// Rufbereitschaft
  DEPLOYMENT    /// Einsatz aus Rufbereitschaft
  ERRAND        /// Dienstgang
  HOME_OFFICE   /// Homeoffice
  TRAINING      /// Fortbildung
  TRAVEL        /// Dienstreise
}

// ---------------------------------------------------------------------------
// Time Accounts & Balances
// ---------------------------------------------------------------------------

model TimeAccount {
  id          String   @id @default(cuid())
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  periodStart DateTime /// Start of accounting period (e.g. month start)
  periodEnd   DateTime /// End of accounting period
  targetHours Decimal  /// Sollzeit for the period
  actualHours Decimal  /// Istzeit for the period
  balance     Decimal  /// actualHours - targetHours
  overtimeHours Decimal @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([personId, periodStart])
  @@map("time_accounts")
}

// ---------------------------------------------------------------------------
// Shift Planning (Roster)
// ---------------------------------------------------------------------------

model Roster {
  id                  String   @id @default(cuid())
  organizationUnitId  String
  organizationUnit    OrganizationUnit @relation(fields: [organizationUnitId], references: [id])
  periodStart         DateTime
  periodEnd           DateTime
  status              RosterStatus @default(DRAFT)
  publishedAt         DateTime?
  shifts              Shift[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("rosters")
}

enum RosterStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Shift {
  id          String   @id @default(cuid())
  rosterId    String
  roster      Roster   @relation(fields: [rosterId], references: [id])
  personId    String?  /// Assigned person (null = unassigned)
  startTime   DateTime
  endTime     DateTime
  shiftType   String   /// e.g. "EARLY", "LATE", "NIGHT"
  minStaffing Int      @default(1)
  bookings    Booking[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("shifts")
}

// ---------------------------------------------------------------------------
// Absences & Leave
// ---------------------------------------------------------------------------

model Absence {
  id            String        @id @default(cuid())
  personId      String
  person        Person        @relation(fields: [personId], references: [id])
  type          AbsenceType
  startDate     DateTime
  endDate       DateTime
  days          Decimal       /// Number of working days
  status        AbsenceStatus @default(REQUESTED)
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([personId, startDate])
  @@map("absences")
}

model OnCallDeployment {
  id              String   @id @default(cuid())
  personId        String
  person          Person   @relation(fields: [personId], references: [id])
  rotationId      String?
  startTime       DateTime
  endTime         DateTime
  remote          Boolean  @default(true)
  ticketReference String?
  eventReference  String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([personId, startTime])
  @@map("oncall_deployments")
}

enum AbsenceType {
  ANNUAL_LEAVE    /// Erholungsurlaub
  SICK            /// Krankheit
  SPECIAL_LEAVE   /// Sonderurlaub
  TRAINING        /// Fortbildung
  TRAVEL          /// Dienstreise
  COMP_TIME       /// Freizeitausgleich
  FLEX_DAY        /// Gleittag
  UNPAID          /// Unbezahlter Urlaub
  PARENTAL        /// Elternzeit
}

enum AbsenceStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Workflow & Approvals
// ---------------------------------------------------------------------------

model WorkflowInstance {
  id            String         @id @default(cuid())
  type          WorkflowType
  status        WorkflowStatus @default(PENDING)
  requesterId   String         /// Person who initiated the request
  approverId    String?        /// Current/final approver
  entityType    String         /// e.g. "Absence", "Booking"
  entityId      String         /// ID of the related entity
  reason        String?
  decidedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("workflow_instances")
}

enum WorkflowType {
  LEAVE_REQUEST
  BOOKING_CORRECTION
  SHIFT_SWAP
  OVERTIME_APPROVAL
  POST_CLOSE_CORRECTION
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Monthly Closing & Export
// ---------------------------------------------------------------------------

model ClosingPeriod {
  id                  String        @id @default(cuid())
  organizationUnitId  String?       /// null = global
  periodStart         DateTime
  periodEnd           DateTime
  status              ClosingStatus @default(OPEN)
  closedAt            DateTime?
  closedById          String?
  exportRuns          ExportRun[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([organizationUnitId, periodStart])
  @@map("closing_periods")
}

enum ClosingStatus {
  OPEN
  REVIEW
  CLOSED
  EXPORTED
}

model ExportRun {
  id              String   @id @default(cuid())
  closingPeriodId String
  closingPeriod   ClosingPeriod @relation(fields: [closingPeriodId], references: [id])
  format          String   /// e.g. "CSV", "XML"
  recordCount     Int
  checksum        String   /// SHA-256 of export content
  exportedAt      DateTime @default(now())
  exportedById    String

  @@map("export_runs")
}

model TerminalSyncBatch {
  id            String   @id @default(cuid())
  terminalId    String
  sourceFile    String?
  importedAt    DateTime @default(now())
  importedById  String?
  rawPayload    Json
  resultPayload Json

  @@index([terminalId, importedAt])
  @@map("terminal_sync_batches")
}

// ---------------------------------------------------------------------------
// Audit Trail (append-only)
// ---------------------------------------------------------------------------

model AuditEntry {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actorId     String   /// Person who performed the action
  action      String   /// e.g. "BOOKING_CREATED", "LEAVE_APPROVED"
  entityType  String   /// e.g. "Booking", "Absence"
  entityId    String
  before      Json?    /// State before change
  after       Json?    /// State after change
  reason      String?  /// Human-readable justification
  ipAddress   String?

  // NOTE: No updatedAt — audit entries are immutable.
  // The DB role for the application should NOT have UPDATE or DELETE
  // permissions on this table.

  @@index([entityType, entityId])
  @@index([actorId, timestamp])
  @@map("audit_entries")
}

{
  "name": "@cueq/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema and database client for cueq",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run src/__tests__/database.smoke.test.ts src/__tests__/database.acceptance.test.ts src/__tests__/database.compliance.test.ts",
    "test:unit": "vitest run",
    "test:integration": "vitest run src/__tests__/database.integration.test.ts",
    "test:acceptance": "vitest run src/__tests__/database.acceptance.test.ts",
    "test:compliance": "vitest run src/__tests__/database.compliance.test.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed:phase2": "node prisma/seed-phase2.mjs seed",
    "db:reset:phase2": "node prisma/seed-phase2.mjs reset",
    "db:seed:phase3": "node prisma/seed-phase3.mjs seed",
    "db:reset:phase3": "node prisma/seed-phase3.mjs reset",
    "db:seed:demo": "node prisma/seed-demo-screenshots.mjs seed",
    "db:reset:demo": "node prisma/seed-demo-screenshots.mjs reset",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "prisma": "^6.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

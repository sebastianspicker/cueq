{
  "name": "@cueq/database",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema and database client for cueq",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0"
  },
  "devDependencies": {
    "prisma": "^6.4.0",
    "typescript": "^5.7.0"
  }
}

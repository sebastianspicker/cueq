{
  "name": "@cueq/core",
  "version": "0.0.0",
  "private": true,
  "description": "Pure domain core logic for cueq",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:integration": "vitest run src/core/__tests__/phase2.integration.test.ts",
    "test:acceptance": "vitest run src/core/__tests__/phase2.acceptance.test.ts",
    "test:compliance": "vitest run src/core/audit/__tests__/build-audit-entry.compliance.test.ts",
    "clean": "rm -rf dist node_modules/.cache coverage"
  },
  "dependencies": {
    "@cueq/policy": "workspace:*",
    "@cueq/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}

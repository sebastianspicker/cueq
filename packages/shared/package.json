{
  "name": "@cueq/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod schemas, types, and utilities for cueq",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:acceptance": "vitest run --passWithNoTests",
    "test:compliance": "vitest run --passWithNoTests",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cueq.dev/schemas/domain/workflow-policy.schema.json",
  "title": "WorkflowPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "escalationDeadlineHours",
    "escalationRoles",
    "maxDelegationDepth",
    "activeFrom",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "$ref": "./_defs/common.schema.json#/$defs/id"
    },
    "type": {
      "enum": [
        "LEAVE_REQUEST",
        "BOOKING_CORRECTION",
        "SHIFT_SWAP",
        "OVERTIME_APPROVAL",
        "POST_CLOSE_CORRECTION"
      ]
    },
    "escalationDeadlineHours": {
      "type": "integer",
      "minimum": 1
    },
    "escalationRoles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "enum": ["TEAM_LEAD", "SHIFT_PLANNER", "HR", "ADMIN"]
      }
    },
    "maxDelegationDepth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "activeFrom": {
      "$ref": "./_defs/common.schema.json#/$defs/dateTime"
    },
    "createdAt": {
      "$ref": "./_defs/common.schema.json#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "./_defs/common.schema.json#/$defs/dateTime"
    }
  }
}

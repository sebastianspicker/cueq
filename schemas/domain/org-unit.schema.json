{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cueq.dev/schemas/domain/org-unit.schema.json",
  "title": "OrganizationUnit",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name"],
  "properties": {
    "id": {
      "$ref": "./_defs/common.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "parentId": {
      "type": ["string", "null"]
    },
    "createdAt": {
      "$ref": "./_defs/common.schema.json#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "./_defs/common.schema.json#/$defs/dateTime"
    }
  }
}

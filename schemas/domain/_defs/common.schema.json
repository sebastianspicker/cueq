{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cueq.dev/schemas/domain/_defs/common.schema.json",
  "$defs": {
    "id": {
      "type": "string",
      "description": "CUID identifier",
      "minLength": 8
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    }
  }
}

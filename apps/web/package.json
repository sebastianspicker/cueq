{
  "name": "@cueq/web",
  "version": "0.0.0",
  "private": true,
  "description": "cueq Next.js web frontend",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:acceptance": "playwright test",
    "test:demo-screenshots": "playwright test --config playwright.demo.config.ts",
    "test:compliance": "vitest run --config vitest.compliance.config.ts",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "dependencies": {
    "@cueq/shared": "workspace:*",
    "next-intl": "^4.4.0",
    "next": "^15.5.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

# cueq — Environment Variables
# ===============================
# Copy to .env and fill in real values.
# NEVER commit .env to the repository.

# Database (PostgreSQL)
DATABASE_URL="postgresql://cueq:cueq_dev_password@localhost:5432/cueq?schema=public"

# API Server
PORT=3001
NODE_ENV=development

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (SSO — to be configured in Phase 2)
# SSO_PROVIDER=oidc
# SSO_ISSUER_URL=https://your-idp.example.com
# SSO_CLIENT_ID=cueq
# SSO_CLIENT_SECRET=change-me-in-production

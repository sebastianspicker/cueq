# cueq — Environment Variables
# ===============================
# Copy to .env and fill in real values.
# NEVER commit .env to the repository.

# Database (PostgreSQL)
DATABASE_URL="postgresql://cueq:cueq_dev_password@localhost:5433/cueq?schema=public"

# API Server
PORT=3001
NODE_ENV=development
# Comma-separated list (for example: https://app.example,https://admin.example).
# In development, localhost origins are allowed by default when unset.
# In production, cross-origin requests are blocked when unset.
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (SSO — to be configured in Phase 2)
# Preferred selector:
AUTH_PROVIDER=mock
# Backward-compatible fallback (deprecated):
AUTH_MODE=mock
OIDC_ISSUER_URL=http://localhost:8081/realms/cueq
OIDC_CLIENT_ID=cueq
SAML_ISSUER=https://saml-idp.cueq.local
SAML_AUDIENCE=cueq-api
SAML_JWT_SECRET=change-me

# Integration tokens (Phase 3)
TERMINAL_GATEWAY_TOKEN=dev-terminal-token
HR_IMPORT_TOKEN=dev-hr-token
HONEYWELL_PROTOCOL=HONEYWELL_CSV_V1

# HR provider adapter mode
HR_PROVIDER_MODE=stub
HR_MASTER_API_URL=https://hr-master.local/api/v1/people
HR_MASTER_API_TOKEN=change-me
HR_MASTER_API_TIMEOUT_MS=10000

# Reporting privacy guardrails
REPORT_MIN_GROUP_SIZE=5

# FR-600 monthly closing
CLOSING_AUTO_CUTOFF_ENABLED=true
CLOSING_CUTOFF_DAY=3
CLOSING_CUTOFF_HOUR=12
CLOSING_TIMEZONE=Europe/Berlin
CLOSING_BOOKING_GAP_MINUTES=240
CLOSING_BALANCE_ANOMALY_HOURS=40
CLOSING_ALLOW_MANUAL_REVIEW_START=false

# Webhook dispatcher
WEBHOOK_DISPATCH_BATCH_SIZE=50
WEBHOOK_REQUEST_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=5

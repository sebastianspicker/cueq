# cueq — Environment Variables
# ===============================
# Copy to .env and fill in real values.
# NEVER commit .env to the repository.

# Database (PostgreSQL)
DATABASE_URL="postgresql://cueq:cueq_dev_password@localhost:5433/cueq?schema=public"

# API Server
PORT=3001
NODE_ENV=development

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth (SSO — to be configured in Phase 2)
AUTH_MODE=mock
OIDC_ISSUER_URL=http://localhost:8081/realms/cueq
OIDC_CLIENT_ID=cueq

# Integration tokens (Phase 3)
TERMINAL_GATEWAY_TOKEN=dev-terminal-token
HR_IMPORT_TOKEN=dev-hr-token

# Reporting privacy guardrails
REPORT_MIN_GROUP_SIZE=5

# Webhook dispatcher
WEBHOOK_DISPATCH_BATCH_SIZE=50
WEBHOOK_REQUEST_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=5
